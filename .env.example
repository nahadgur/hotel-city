# ============================================
# Stayward — Environment Variables
# ============================================
# Copy this to .env.local for local dev, and add each to Vercel for deploy.
#
# No vars set = site runs in mock mode (no search, no emails, no auth).
# Set the Part 2 + 3 + 4a vars to unlock the full product.

# ---- Part 2: Agentic search (Anthropic + OpenAI + Pinecone) ----
# Get these from console.anthropic.com, platform.openai.com, pinecone.io
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
PINECONE_API_KEY=
PINECONE_INDEX_NAME=stayward-vibes

# ---- Part 3: Brief pipeline (Supabase + Resend) ----
# Get these from supabase.com (project API settings) and resend.com (API keys)
NEXT_PUBLIC_SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
RESEND_API_KEY=
# Random 32+ char string — used to sign brief magic links
BRIEF_SIGNING_SECRET=

# ---- Part 4a: Auth (Google OAuth via NextAuth) ----
# Get these from console.cloud.google.com (OAuth 2.0 Client IDs)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Random 32+ char string — used to sign NextAuth JWTs
NEXTAUTH_SECRET=
# Must match your deployment URL (or http://localhost:3000 for local dev)
NEXTAUTH_URL=https://stayward.vercel.app

# ---- Optional: once you have a real domain ----
# Without these, emails send from Resend's test sender to your Resend account email only.
# With them, the full inbound/outbound flow works end-to-end.
# RESEND_INBOUND_DOMAIN=reply.stayward.com
# RESEND_FROM_ADDRESS=Stayward <hotels@stayward.com>
# NEXT_PUBLIC_SITE_URL=https://stayward.com
